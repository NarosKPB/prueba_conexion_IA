	column Inicio_Semana = ```
			
			VAR _FechaActual = 'Dim_Tiempo'[Fecha]
			
			// 1. Calculamos el lunes de la semana
			VAR _InicioSemana = _FechaActual - WEEKDAY(_FechaActual, 2) + 1
			
			// 2. Extraemos el día y le ponemos la primera letra en mayúscula
			VAR _DiaNombre = FORMAT(_InicioSemana, "dddd") 
			VAR _DiaMayuscula = UPPER(LEFT(_DiaNombre, 1)) & MID(_DiaNombre, 2, LEN(_DiaNombre))
			
			// 3. Extraemos número, mes y año
			VAR _DiaNumero = FORMAT(_InicioSemana, "d")
			VAR _MesNombre = FORMAT(_InicioSemana, "mmmm")
			VAR _Ano = FORMAT(_InicioSemana, "yyyy")
			
			// 4. Unimos todo
			RETURN 
			_DiaNumero & " de " & _MesNombre & " " & _Ano
			```
		lineageTag: c44e9799-993f-4533-bbba-77c6b2fa8ada
		summarizeBy: none
		sortByColumn: Semana

		changedProperty = SortByColumn

		annotation SummarizationSetBy = Automatic

	column Dia_Corto_Fecha =
			
			SWITCH(
			    'Dim_Tiempo'[Dia_Semana_Abrv],
			    "lu.", "Lun",
			    "ma.", "Mar",
			    "mi.", "Mié",
			    "ju.", "Jue",
			    "vi.", "Vie",
			    "sá.", "Sáb",
			    "do.", "Dom",
			    'Dim_Tiempo'[Dia_Semana_Abrv]
			)
			& " " &
			FORMAT('Dim_Tiempo'[Fecha], "dd")
		lineageTag: 0d31da30-ad9b-4d4d-8973-eb98bcbac3d5
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition Dim_Tiempo = m
		mode: import
		source =
				let
				    Origen = Value.NativeQuery(GoogleBigQuery.Database([BillingProject="kpb-general"]){[Name="kpb-general"]}[Data], "SELECT * FROM VistasGenerales.Dim_Tiempo#(lf)WHERE fecha >= '2026-01-01' AND fecha <= CURRENT_DATE", null, [EnableFolding=true])
				in
				    Origen

	annotation PBI_ResultType = Table

