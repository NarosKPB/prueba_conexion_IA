	measure 'Validación Fanea vs Planificacion' = ```
			
			var _faena = [Cantidad de Reportes de Faenas]
			var _planificado = [Cantidad Planificacion]
			return 
			    SWITCH(TRUE(),
			    ISBLANK(_faena) && ISBLANK(_planificado),BLANK(),
			    _faena > 0 && _planificado = 1, 1,
			    _faena > 0 && _planificado = 0, 2,
			    _faena = _planificado, 1,
			
			    0
			    )
			```
		formatString: 0
		lineageTag: 13d9003e-403e-4db8-a32a-8de1d333b584

	measure 'Porc Cumplimiento Reportes' =
			
			var _planificado = [Cantidad Planificacion]
			var _reportes = [Cantidad de Reportes de Faenas]
			var _resultado = DIVIDE(_reportes,_planificado,0)
			return _resultado
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: a817375f-e6f1-480e-ba56-3489cc0929fe

	measure Matriz_Simple_SVG =
			
			VAR Plan = [Cantidad Planificacion]
			VAR Real = [Cantidad de Reportes de Faenas]
			
			VAR Plan0 = COALESCE(Plan, 0)
			VAR Real0 = COALESCE(Real, 0)
			
			VAR TieneDatos =
			    NOT(ISBLANK(Plan) && ISBLANK(Real))
			
			VAR Cumplimiento =
			    IF(
			        Plan0 > 0,
			        MIN(DIVIDE(Real0, Plan0, 0), 1),
			        0
			    )
			
			VAR BarraAncho =
			    Cumplimiento * 82
			
			VAR ColorEstado =
			    SWITCH(
			        TRUE(),
			        Plan0 = Real0, "#22C55E",                -- verde
			        Real0 > 0 && Real0 < Plan0, "#F59E0B",  -- naranja
			        "#EF4444"                               -- rojo
			    )
			
			VAR Etiqueta =
			    "Plan " & FORMAT(Plan0, "0") & "  Rep " & FORMAT(Real0, "0")
			
			RETURN
			IF(
			    NOT TieneDatos,
			    BLANK(),
			    "data:image/svg+xml;utf8," &
			    "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 52' preserveAspectRatio='xMidYMid meet'>
			
			        <rect x='3' y='5' width='92' height='34' rx='5'
			              fill='#FFFFFF'
			              stroke='#D9D9D9'
			              stroke-width='1'/>
			
			        <circle cx='12' cy='15' r='3.2' fill='" & ColorEstado & "'/>
			
			        <text x='19' y='17'
			              font-family='Segoe UI, Arial, sans-serif'
			              font-size='10.5'
			              font-weight='700'
			              fill='#1F2937'>" & Etiqueta & "</text>
			
			        <rect x='12' y='23' width='82' height='5.5' rx='2.7'
			              fill='#E5E7EB'/>
			
			        <rect x='12' y='23' width='" & BarraAncho & "' height='5.5' rx='2.7'
			              fill='" & ColorEstado & "'/>
			
			    </svg>"
			)
		lineageTag: 31a9dd75-6c35-4424-9ed3-063c13ab8014
		dataCategory: ImageUrl

	measure 'Matriz_Simple_SVG 2' =
			
			VAR Plan = ROUND([Cantidad Planificacion], 0)
			VAR Real = ROUND([Cantidad de Reportes de Faenas], 0)
			
			VAR Plan0 = COALESCE(Plan, 0)
			VAR Real0 = COALESCE(Real, 0)
			
			VAR TieneDatos =
			    NOT(ISBLANK(Plan) && ISBLANK(Real))
			
			VAR Estado =
			    SWITCH(
			        TRUE(),
			        Plan0 = Real0, "verde",
			        Plan0 > Real0, "rojo",
			        Real0 > Plan0, "naranjo",
			        "gris"
			    )
			
			VAR ColorEstado =
			    SWITCH(
			        Estado,
			        "verde", "#22C55E",
			        "rojo", "#EF4444",
			        "naranjo", "#F59E0B",
			        "#D1D5DB"
			    )
			
			VAR IconoSVG =
			    SWITCH(
			        Estado,
			
			        /* Verde: check */
			        "verde",
			        "<path d='M9 16 L12 19 L18 11'
			            stroke='#22C55E'
			            stroke-width='2.2'
			            stroke-linecap='round'
			            stroke-linejoin='round'
			            fill='none'/>",
			
			        /* Rojo: cruz */
			        "rojo",
			        "<path d='M9 11 L17 19 M17 11 L9 19'
			            stroke='#EF4444'
			            stroke-width='2.2'
			            stroke-linecap='round'
			            fill='none'/>",
			
			        /* Naranjo: signo ! */
			        "naranjo",
			        "<line x1='13' y1='10.5' x2='13' y2='16.5'
			            stroke='#F59E0B'
			            stroke-width='2.2'
			            stroke-linecap='round'/>
			         <circle cx='13' cy='19' r='1.2' fill='#F59E0B'/>",
			
			        /* Gris */
			        "<circle cx='13' cy='15' r='2.5' fill='#D1D5DB'/>"
			    )
			
			VAR ColorBorde = "#D9D9D9"
			VAR ColorFondo = "#FFFFFF"
			VAR ColorTextoTitulo = "#6B7280"
			VAR ColorTextoNumero = "#111827"
			VAR ColorBarraBase = "#E5E7EB"
			
			RETURN
			IF(
			    NOT TieneDatos,
			    BLANK(),
			    "data:image/svg+xml;utf8," &
			    "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 90 78' preserveAspectRatio='xMidYMid meet'>
			
			        <!-- tarjeta -->
			        <rect x='3' y='4' width='94' height='50' rx='7'
			              fill='" & ColorFondo & "'
			              stroke='" & ColorBorde & "'
			              stroke-width='1'/>
			
			        <!-- icono estado -->
			        " & IconoSVG & "
			
			        <!-- títulos -->
			        <text x='22' y='17'
			              font-family='Segoe UI, Arial, sans-serif'
			              font-size='12'
			              font-weight='600'
			              fill='" & ColorTextoTitulo & "'>Plan</text>
			
			        <text x='60' y='17'
			              font-family='Segoe UI, Arial, sans-serif'
			              font-size='12'
			              font-weight='600'
			              fill='" & ColorTextoTitulo & "'>Repo</text>
			
			        <!-- números -->
			        <text x='22' y='33'
			              font-family='Segoe UI, Arial, sans-serif'
			              font-size='13.5'
			              font-weight='700'
			              fill='" & ColorTextoNumero & "'>" & FORMAT(Plan0, "0") & "</text>
			
			        <text x='60' y='33'
			              font-family='Segoe UI, Arial, sans-serif'
			              font-size='13.5'
			              font-weight='700'
			              fill='" & ColorTextoNumero & "'>" & FORMAT(Real0, "0") & "</text>
			
			        <!-- barra base -->
			        <rect x='12' y='40' width='82' height='6' rx='3'
			              fill='" & ColorBarraBase & "'/>
			
			        <!-- barra estado fija -->
			        <rect x='12' y='40' width='82' height='6' rx='3'
			              fill='" & ColorEstado & "'/>
			
			    </svg>"
			)
		lineageTag: c33b6009-0747-450f-87b1-c000bc55bbab
		dataCategory: ImageUrl

