table Medidas
	lineageTag: 9b23d865-0bc9-4fcf-a5a5-a3d6c2a12e79

	measure 'Tiempo Promedio Minutos En Faena' =
			
			var _minutos_promedio = AVERAGE(Reporte_Faenas[Diferencia Minutos Inicio - Fin Faena])
			return _minutos_promedio
		lineageTag: 46997f67-e8dd-4952-a371-b504868c7c23

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Tiempo Promedio Horas En Faena' =
			
			var _minutos_totales = [Tiempo Promedio Minutos En Faena]
			var _horas = INT(_minutos_totales / 60)
			var _minutos = MOD(_minutos_totales, 60)
			
			// 4. Une todo forzando el formato de dos dígitos (00)
			return FORMAT(_horas, "00") & ":" & FORMAT(_minutos, "00")
		lineageTag: d182fd61-614a-4736-addc-5f94192e9ba3

	measure 'Cantidad de Reportes de Faenas' = DISTINCTCOUNT(Reporte_Faenas[code])
		formatString: 0
