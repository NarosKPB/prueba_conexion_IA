	measure 'Tiempo Promedio Visual' =
			
			VAR _min = [Tiempo Promedio Min]
			VAR _horas = INT(DIVIDE(_min, 60))
			VAR _mins = ROUND(MOD(_min, 60), 0)
			RETURN
			FORMAT(_horas, "0") & " h " & FORMAT(_mins, "00") & " min"
		lineageTag: 3b16efc0-8091-47b6-82f2-7eaeb300f1d5

	measure 'Tiempo Total Min' =
			
			SUM( Reporte_Faenas[Diferencia Minutos Inicio - Fin Faena] )
