		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Tiempo Total' =
			
			VAR _min = [Tiempo Total Min]
			VAR _horas = INT( DIVIDE(_min, 60) )
			VAR _mins = MOD(_min, 60)
			RETURN
			FORMAT(_horas, "00") & ":" & FORMAT(_mins, "00")
