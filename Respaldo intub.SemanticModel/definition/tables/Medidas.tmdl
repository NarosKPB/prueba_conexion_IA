	measure 'Cantidad Mes Pasado' =
			
			CALCULATE(
			    [Cantidad de Reportes de Faenas],
			    DATEADD(Dim_Tiempo[Fecha], -1, MONTH)
			)
		formatString: 0
		lineageTag: 715f2ab0-2f60-47de-85f4-a3498986fd37

	measure 'Dif vs Mes Pasado' =
			
			[Cantidad de Reportes de Faenas] - [Cantidad Mes Pasado]
		formatString: 0
		lineageTag: 4f4fe731-6898-48fa-ba99-7e15cb6df4b9

	measure 'Texto Mes Pasado Tarjeta reporte' =
			
			VAR _actual = [Cantidad de Reportes de Faenas]
			VAR _pasado = [Cantidad Mes Pasado]
			VAR _dif = _actual - _pasado
			VAR _flecha_up = UNICHAR(129137)
			VAR _flecha_down = UNICHAR(129139)
			VAR _flecha =
			    SWITCH(
			        TRUE(),
			        _dif > 0, _flecha_up,
			        _dif < 0, _flecha_down,
			        ""
			    )
			VAR _signo =
			    SWITCH(
			        TRUE(),
			        _dif > 0, "+",
			        _dif < 0, "",
			        ""
			    )
			RETURN
			    _signo & FORMAT(_dif, "#,##0")
			    & " "
			    & _flecha
		lineageTag: 1e8f1529-5b48-4057-88eb-5a4409cd2aef

	measure 'Color Mes Pasado Tarjeta reporte' =
			
			VAR _dif = [Cantidad de Reportes de Faenas] - [Cantidad Mes Pasado]
			RETURN
			SWITCH(
			    TRUE(),
			    _dif > 0, "#16A34A",   -- verde
			    _dif < 0, "#DC2626",   -- rojo
			    "#6B7280"              -- gris
			)
		lineageTag: b17636c9-7f35-41d4-819e-71224699d418

