	column Hora
		dataType: dateTime
		formatString: Long Time
		lineageTag: cfc640fd-80f8-4d21-a26b-88b6879aff54
		summarizeBy: none
		sourceColumn: Hora

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Time

	column Hora_Numero
		dataType: int64
		formatString: 0
		lineageTag: 21fc810d-824a-412e-a757-8aec7728b73e
		summarizeBy: none
		sourceColumn: Hora_Numero

		annotation SummarizationSetBy = Automatic

	column Minuto_Numero
		dataType: int64
		formatString: 0
		lineageTag: 2f64d106-ae60-4b2e-8259-6d9357f64fef
		summarizeBy: none
		sourceColumn: Minuto_Numero

